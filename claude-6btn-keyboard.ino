            if (z2y > 10) {
                u8g2.setFont(u8g2_font_5x7_tf);
                u8g2.drawStr(z2x, z2y, "z");
            }
            // Z3
            int z3y = 42 - ((offset + 20) % 30);
            int z3x = 68 + (((offset + 20) % 30) / 3);
            if (z3y > 10) {
                u8g2.setFont(u8g2_font_6x10_tf); // larger Z
                u8g2.drawStr(z3x, z3y, "Z");
            }
            break;
        }

        case STATE_WAKEUP: {
            // Wakeup stretch animation (lasts 4000ms)
            uint32_t elapsed = now - stateStartTs;
            float progress = (float)elapsed / 4000.0f;
            if (progress > 1.0f) progress = 1.0f;

            // Screen starts empty/clean. No background drawn!

            // Draw stretching yawning/smiling mouth
            u8g2.setDrawColor(1);
            if (progress < 0.8f) {
                float stretchScale = sin(progress * (PI / 0.8f));
                int rx = 3 + (int)(5.0f * stretchScale);
                int ry = 2 + (int)(7.0f * stretchScale);
                u8g2.drawDisc(64, 40, rx);
            } else {
                u8g2.drawHLine(61, 40, 6);
                u8g2.drawPixel(60, 39);
                u8g2.drawPixel(67, 39);
            }

            // Draw stretching hands!
            float stretchProgress = 0.0f;
            if (progress < 0.6f) {
                stretchProgress = sin(progress * (PI / 2.0f) / 0.6f);
            } else if (progress < 1.4f) {
                stretchProgress = 1.0f;
            } else {
                stretchProgress = 1.0f - sin((progress - 1.4f) * (PI / 2.0f) / 0.6f);
            }

            // Add organic tremble to hands when fully stretched
            float trembleX = 0.0f;
            float trembleY = 0.0f;
            if (progress >= 0.5f && progress <= 1.4f) {
                trembleX = sin((float)now * 0.15f) * 1.2f;
                trembleY = cos((float)now * 0.2f) * 1.2f;
            }

            // Left hand coordinates
            int lhX = 52 - (int)(stretchProgress * 26.0f) + (int)trembleX;
            int lhY = 48 - (int)(stretchProgress * 20.0f) + (int)trembleY;

            // Right hand coordinates
            int rhX = 76 + (int)(stretchProgress * 26.0f) + (int)trembleX;
            int rhY = 48 - (int)(stretchProgress * 20.0f) + (int)trembleY;

            // Draw arm lines connecting body to hands
            u8g2.drawLine(46, 48, lhX, lhY);
            u8g2.drawLine(47, 48, lhX + 1, lhY);
            u8g2.drawLine(82, 48, rhX, rhY);
            u8g2.drawLine(81, 48, rhX - 1, rhY);

            // Draw hands
            u8g2.drawDisc(lhX, lhY, 3);
            u8g2.drawDisc(rhX, rhY, 3);

            // Draw tiny finger lines
            u8g2.drawLine(lhX, lhY, lhX - 2, lhY - 3);
            u8g2.drawLine(lhX, lhY, lhX - 3, lhY);
            u8g2.drawLine(lhX, lhY, lhX - 2, lhY + 3);
            u8g2.drawLine(rhX, rhY, rhX + 2, rhY - 3);
            u8g2.drawLine(rhX, rhY, rhX + 3, rhY);
            u8g2.drawLine(rhX, rhY, rhX + 2, rhY + 3);

            break;
        }
    }

    u8g2.sendBuffer();
}

// ── SETUP ─────────────────────────────────────────────────────
void setup(void) {
    Serial.begin(115200);
    delay(800);
    Serial.println("\n=========================================");
    Serial.println("  ESP32-S3 Super Mini — Claude Keyboard  ");
    Serial.println("=========================================");

    // Onboard LED
    pinMode(LED_PIN, OUTPUT);
    digitalWrite(LED_PIN, HIGH);  // HIGH = off (active LOW)

    // Touch Sensor (pull-down ensures standard low state)
    pinMode(TOUCH_PIN, INPUT_PULLDOWN);

    // Keyboard Buttons — internal pull-up, active LOW
    for (auto& b : buttons) {
        pinMode(b.pin, INPUT_PULLUP);
    }

    // Initialize OLED display using standard U8g2 I2C configuration
    Wire.begin(PIN_SDA, PIN_SCL);
    u8g2.begin();

    // Initialize speaker buzzer PWM channel
#if ESP_ARDUINO_VERSION_MAJOR < 3
    ledcSetup(0, 2000, 8);
    ledcAttachPin(SPEAKER_PIN, 0);
#else
    ledcAttach(SPEAKER_PIN, 2000, 8);
#endif

    // Initialize NimBLE BLE stack
    NimBLEDevice::init("Claude Keyboard");
    NimBLEDevice::setSecurityAuth(true, true, true);

    NimBLEServer* pServer = NimBLEDevice::createServer();
    pServer->setCallbacks(new ServerCallbacks());

    hid   = new NimBLEHIDDevice(pServer);
    input = hid->getInputReport(1);  // Report ID 1

    hid->setManufacturer("DIY");
    hid->setPnp(0x02, 0x05ac, 0x820a, 0x0210);
    hid->setHidInfo(0x00, 0x01);
    hid->setReportMap((uint8_t*)hidReportDescriptor, sizeof(hidReportDescriptor));

    pServer->start();

    NimBLEAdvertising* pAdv = NimBLEDevice::getAdvertising();
    pAdv->setAppearance(961);  // HID Keyboard
    pAdv->addServiceUUID(hid->getHidService()->getUUID());
    pAdv->start();

    Serial.println("[BLE] Advertising started — waiting for host...");
}

// ── LOOP ──────────────────────────────────────────────────────
void loop() {
    uint32_t now = millis();
    static uint32_t lastActivityTs = 0;
    if (lastActivityTs == 0) lastActivityTs = now;

    // Connection state changes
    if (isConnected && !wasConnected) {
        Serial.println("[BLE] CONNECTED ✓");
        digitalWrite(LED_PIN, LOW);   // LED ON
        wasConnected = true;
    }
    if (!isConnected && wasConnected) {
        Serial.println("[BLE] DISCONNECTED — re-advertising...");
        for (auto& b : buttons) b.keyDown = false;
        chordActive = false;
        wasConnected = false;
    }

    // Blink LED while disconnected
    if (!isConnected) {
        digitalWrite(LED_PIN, (now / 500) % 2 ? LOW : HIGH);
    } else {
        digitalWrite(LED_PIN, LOW);
    }

    // ── Per-button debounce + press/release/repeat ─────────────
    bool reportChanged = false;

    for (auto& b : buttons) {
        bool raw = digitalRead(b.pin);  // LOW = pressed

        if (raw != b.lastRaw) {
            b.debounceTs = now;
            b.lastRaw    = raw;
        }

        if ((now - b.debounceTs) >= DEBOUNCE_MS && raw != b.physState) {
            b.physState = raw;

            if (raw == LOW) {
                if (!b.keyDown) {
                    b.keyDown  = true;
                    b.pressTs  = now;
                    b.repeatTs = now;
                    
                    if (b.pin == BTN_PLAN) {
                        Serial.println("[KEY] PLAN pressed - Sending Shift + Tab twice");
                        if (isConnected) {
                            sendReport(KEY_MOD_LSHIFT, KEY_TAB, 0, 0);
                            delay(15);
                            sendRelease();
                            delay(50);
                            sendReport(KEY_MOD_LSHIFT, KEY_TAB, 0, 0);
                            delay(15);
                            sendRelease();
                        }
                    } else {
                        reportChanged = true;
                        Serial.printf("[KEY] Pin %d pressed (key: 0x%02X)\n", b.pin, b.hidKey);
                    }
                }
            } else {
                if (b.keyDown) {
                    b.keyDown = false;
                    if (b.pin != BTN_PLAN) {
                        reportChanged = true;
                        Serial.printf("[KEY] Pin %d released (key: 0x%02X)\n", b.pin, b.hidKey);
                    }
                }
            }
        }

        if (b.pin != BTN_PLAN && b.pin != BTN_MIC && b.keyDown && b.physState == LOW) {
            uint32_t heldMs = now - b.pressTs;
            if (heldMs >= REPEAT_DELAY) {
                if ((now - b.repeatTs) >= REPEAT_RATE) {
                    b.repeatTs = now;
                    reportChanged = true;
                }
            }
        }
    }

    // ── Key Chords (Combos) ──────────────────────────────────────
    static bool micAcceptActive  = false;
    static bool acceptUpActive    = false;
    static bool acceptDownActive  = false;
    static bool micDownActive    = false;

    bool micPressed    = (buttons[1].physState == LOW);
    bool acceptPressed = (buttons[2].physState == LOW);
    bool upPressed     = (buttons[4].physState == LOW);
    bool downPressed   = (buttons[5].physState == LOW);

    // 1. mic + accept -> tab
    if (micPressed && acceptPressed) {
        if (!micAcceptActive) {
            micAcceptActive = true;
            Serial.println("[CHORD] MIC + ACCEPT -> TAB");
            buttons[1].keyDown = false;
            buttons[2].keyDown = false;
            if (isConnected) {
                sendRelease();
                delay(15);
                sendReport(0, KEY_TAB, 0, 0);
                delay(15);
                sendRelease();
            }
            reportChanged = true;
            playTone(1000, 30);
        }
    } else {
        micAcceptActive = false;
    }

    // 2. accept + up -> Cmd + [ (Backward)
    if (acceptPressed && upPressed) {
        if (!acceptUpActive) {
            acceptUpActive = true;
            Serial.println("[CHORD] ACCEPT + UP -> Cmd + [");
            buttons[2].keyDown = false;
            buttons[4].keyDown = false;
            if (isConnected) {
                sendRelease();
                delay(15);
                sendReport(KEY_MOD_LGUI, KEY_LEFT_BRACKET, 0, 0);
                delay(15);
                sendRelease();
            }
            reportChanged = true;
            playTone(1000, 30);
        }
    } else {
        acceptUpActive = false;
    }

    // 3. accept + down -> Cmd + ] (Forward)
    if (acceptPressed && downPressed) {
        if (!acceptDownActive) {
            acceptDownActive = true;
            Serial.println("[CHORD] ACCEPT + DOWN -> Cmd + ]");
            buttons[2].keyDown = false;
            buttons[5].keyDown = false;
            if (isConnected) {
                sendRelease();
                delay(15);
                sendReport(KEY_MOD_LGUI, KEY_RIGHT_BRACKET, 0, 0);
                delay(15);
                sendRelease();
            }
            reportChanged = true;
            playTone(1000, 30);
        }
    } else {
        acceptDownActive = false;
    }

    // 4. mic + down -> F5 (Mac Dictation)
    if (micPressed && downPressed) {
        if (!micDownActive) {
            micDownActive = true;
            Serial.println("[CHORD] MIC + DOWN -> F5");
            buttons[1].keyDown = false;
            buttons[5].keyDown = false;
            if (isConnected) {
                sendRelease();
                delay(15);
                sendReport(0, KEY_F5, 0, 0);
                delay(15);
                sendRelease();
            }
            reportChanged = true;
            playTone(1000, 30);
        }
    } else {
        micDownActive = false;
    }

    // Send combined report if anything changed AND we are connected
    if (isConnected && reportChanged) {
        sendCombinedReport();
    }

    // ── Touch Sensor Interactions ──────────────────────────────
    bool rawTouch = (digitalRead(TOUCH_PIN) == HIGH);
    static bool lastRawTouch = false;
    
    if (rawTouch && !lastRawTouch) {
        Serial.println("[TOUCH] Sensor clicked! Sending Cmd + Shift + ) shortcut to open Claude...");
        if (isConnected) {
            sendReport(KEY_MOD_LGUI | KEY_MOD_LSHIFT, KEY_0, 0, 0);
            delay(15);
            sendRelease();
        }
        purrSound();
        // Trigger wakeup / hand stretching animation!
        activeState = STATE_WAKEUP;
        stateStartTs = now;
    }
    lastRawTouch = rawTouch;
    
    if (rawTouch) {
        static uint32_t lastPurrTs = 0;
        if (now - lastPurrTs >= 1200) {
            lastPurrTs = now;
            purrSound();
        }
    }

    // ── Animation State Selection & Timing ───────────────────────
    ScreenState targetState = STATE_IDLE;
    uint32_t oneShotDuration = 2500; // 2.5 seconds
    uint32_t yawnDuration    = 2000; // 2.0 seconds yawning/wakeup

    // Keep track of sleep state
    static bool wasSleeping = false;

    // 1. Keep playing one-shot if active
    if (activeState == STATE_ROCKET || activeState == STATE_PLAN || activeState == STATE_ESC || activeState == STATE_YAWN || activeState == STATE_WAKEUP) {
        uint32_t dur = (activeState == STATE_YAWN || activeState == STATE_WAKEUP) ? yawnDuration : oneShotDuration;
        if (now - stateStartTs < dur) {
            targetState = activeState;
        } else {
            activeState = STATE_IDLE;
        }
    }

    // 2. High priority: MIC pressed/held -> Recording Wave
    if (buttons[1].physState == LOW) {
        targetState = STATE_MIC;
        activeState = STATE_MIC;
    }
    // 3. Trigger One-shot reactions
    else if (buttons[2].physState == LOW) { // ACCEPT -> Rocket
        if (activeState != STATE_ROCKET) {
            activeState = STATE_ROCKET;
            stateStartTs = now;
            playTone(400, 80);
        }
        targetState = STATE_ROCKET;
    }
    else if (buttons[3].physState == LOW) { // PLAN -> Brain / Neural
        if (activeState != STATE_PLAN) {
            activeState = STATE_PLAN;
            stateStartTs = now;
            happySound();
        }
        targetState = STATE_PLAN;
    }
    else if (buttons[0].physState == LOW) { // ESC -> Bomb
        if (activeState != STATE_ESC) {
            activeState = STATE_ESC;
            stateStartTs = now;
            playTone(600, 60);
            playTone(900, 60);
            playTone(1300, 100);
        }
        targetState = STATE_ESC;
    }
    // 4. Low priority: UP / DOWN held -> Scrolling Chevrons
    else if (buttons[4].physState == LOW) { // UP
        targetState = STATE_LOOK_UP;
    }
    else if (buttons[5].physState == LOW) { // DOWN
        targetState = STATE_LOOK_DOWN;
    }

    // Activity tracking to reset sleep timer
    bool hasActivity = false;
    for (auto& b : buttons) {
        if (b.physState == LOW) {
            hasActivity = true;
        }
    }
    if (rawTouch) {
        hasActivity = true;
    }
    
    // If waking up from sleep, trigger the wakeup animation state
    if (hasActivity && wasSleeping) {
        activeState = STATE_WAKEUP;
        stateStartTs = now;
        targetState = STATE_WAKEUP;
    }

    if (hasActivity) {
        lastActivityTs = now;
    }

    // If idle for more than 1 minute (60,000 ms), show sleeping emoji
    if (targetState == STATE_IDLE && (now - lastActivityTs >= 60000)) {
        targetState = STATE_SLEEP;
    }

    wasSleeping = (targetState == STATE_SLEEP);

    // Render display at a fixed 50 FPS (every 20 ms)
    static uint32_t lastDisplayUpdateTs = 0;
    if (now - lastDisplayUpdateTs >= 20) {
        lastDisplayUpdateTs = now;
        drawScreenState(targetState, now);
    }
}
