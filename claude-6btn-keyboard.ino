// ── HID report helpers ────────────────────────────────────────
void sendReport(uint8_t modifier, uint8_t key1, uint8_t key2, uint8_t key3) {
    if (!isConnected || !input) return;
    uint8_t report[8] = { modifier, 0, key1, key2, key3, 0, 0, 0 };
    input->setValue(report, sizeof(report));
    input->notify();
}

void sendRelease() {
    sendReport(0, 0, 0, 0);
}

void sendCombinedReport() {
    uint8_t keys[3] = {0, 0, 0};
    uint8_t idx = 0;
    for (auto& b : buttons) {
        if (b.keyDown && idx < 3) keys[idx++] = b.hidKey;
    }
    sendReport(0, keys[0], keys[1], keys[2]);
}

// ── SCREEN STATES ─────────────────────────────────────────────
static ScreenState activeState   = STATE_IDLE;
static uint32_t    stateStartTs  = 0;

// ── SOUND ─────────────────────────────────────────────────────
void playTone(int freq, int duration) {
#if ESP_ARDUINO_VERSION_MAJOR < 3
    if (freq > 0) {
        ledcWriteTone(0, freq);
    } else {
        ledcWriteTone(0, 0);
    }
    delay(duration);
    ledcWriteTone(0, 0);
#else
    if (freq > 0) {
        ledcWriteTone(SPEAKER_PIN, freq);
    } else {
        ledcWriteTone(SPEAKER_PIN, 0);
    }
    delay(duration);
    ledcWriteTone(SPEAKER_PIN, 0);
#endif
}

void happySound() {
    playTone(988, 120);
    playTone(1318, 120);
    playTone(1760, 150);
}

void purrSound() {
#if ESP_ARDUINO_VERSION_MAJOR < 3
    ledcWriteTone(0, 160); // cozy low-pitched rumble
    delay(80);
    ledcWriteTone(0, 0);
#else
    ledcWriteTone(SPEAKER_PIN, 160);
    delay(80);
    ledcWriteTone(SPEAKER_PIN, 0);
#endif
}

// ── PROCEDURAL GRAPHICS RENDERER (Restored Mochi Face & Full Screen Animations) ──
void drawScreenState(ScreenState state, uint32_t now) {
    u8g2.clearBuffer();

    // Slower frame rate for Mochi idle breathing (90ms per frame)
    static uint32_t lastMochiFrameTs = 0;
    static int normalFrame = 0;
    if (now - lastMochiFrameTs >= 90) {
        lastMochiFrameTs = now;
        normalFrame = (normalFrame + 1) % NORMAL_FRAME_COUNT;
    }

    switch (state) {
        case STATE_IDLE: {
            // Draw the classic high-fidelity Mochi face!
            u8g2.drawXBMP(0, -5, 128, 64, normalFrames[normalFrame]);
            break;
        }

        case STATE_LOOK_UP: {
            // Clean screen — no background bitmap drawn!
            u8g2.setDrawColor(1);

            // ── Determined chevron eyes ──────────────────────────
            // Left eye: ">" shape
            u8g2.drawLine(32, 16, 40, 22);  // top-right diagonal
            u8g2.drawLine(40, 22, 32, 28);  // bottom-right diagonal
            u8g2.drawLine(33, 16, 41, 22);  // bold: top-right diagonal
            u8g2.drawLine(41, 22, 33, 28);  // bold: bottom-right diagonal
            u8g2.drawLine(34, 16, 42, 22);  // extra bold
            u8g2.drawLine(42, 22, 34, 28);

            // Right eye: "<" shape
            u8g2.drawLine(96, 16, 88, 22);  // top-left diagonal
            u8g2.drawLine(88, 22, 96, 28);  // bottom-left diagonal
            u8g2.drawLine(95, 16, 87, 22);  // bold
            u8g2.drawLine(87, 22, 95, 28);
            u8g2.drawLine(94, 16, 86, 22);  // extra bold
            u8g2.drawLine(86, 22, 94, 28);

            // ── Large scrolling up arrow centered at x=64 ────────
            int speed  = 25; // ms per pixel
            int period = 50; // px between arrow tips
            int offset = (now / speed) % period;

            for (int i = -1; i < 3; i++) {
                int tipY = 60 - offset - i * period; // tip of arrowhead scrolls upward
                if (tipY < -15 || tipY > 75) continue;

                // Arrowhead — bold filled triangle
                for (int t = 0; t <= 10; t++) {
                    u8g2.drawLine(64 - t, tipY + t, 64 + t, tipY + t);
                }

                // Stem — double-wide line below arrowhead
                int stemTop = tipY + 11;
                int stemBot = tipY + 30;
                if (stemBot > 63) stemBot = 63;
                if (stemTop <= stemBot) {
                    u8g2.drawLine(63, stemTop, 63, stemBot);
                    u8g2.drawLine(64, stemTop, 64, stemBot);
                    u8g2.drawLine(65, stemTop, 65, stemBot);
                }
            }
            break;
        }

        case STATE_LOOK_DOWN: {
            // Clean screen — no background bitmap drawn!
            u8g2.setDrawColor(1);

            // ── Determined chevron eyes ──────────────────────────
            // Left eye: ">" shape (same expression as up)
            u8g2.drawLine(32, 16, 40, 22);
            u8g2.drawLine(40, 22, 32, 28);
            u8g2.drawLine(33, 16, 41, 22);
            u8g2.drawLine(41, 22, 33, 28);
            u8g2.drawLine(34, 16, 42, 22);
            u8g2.drawLine(42, 22, 34, 28);

            // Right eye: "<" shape
            u8g2.drawLine(96, 16, 88, 22);
            u8g2.drawLine(88, 22, 96, 28);
            u8g2.drawLine(95, 16, 87, 22);
            u8g2.drawLine(87, 22, 95, 28);
            u8g2.drawLine(94, 16, 86, 22);
            u8g2.drawLine(86, 22, 94, 28);

            // ── Large scrolling down arrow centered at x=64 ──────
            int speed  = 25; // ms per pixel
            int period = 50; // px between arrow tips
            int offset = (now / speed) % period;

            for (int i = -1; i < 3; i++) {
                int tipY = 3 + offset + i * period; // tip (bottom) scrolls downward
                if (tipY < -15 || tipY > 75) continue;

                // Arrowhead — bold filled triangle pointing down
                for (int t = 0; t <= 10; t++) {
                    u8g2.drawLine(64 - t, tipY - t, 64 + t, tipY - t);
                }

                // Stem — double-wide line above arrowhead
                int stemBot = tipY - 11;
                int stemTop = tipY - 30;
                if (stemTop < 0) stemTop = 0;
                if (stemTop <= stemBot) {
                    u8g2.drawLine(63, stemTop, 63, stemBot);
                    u8g2.drawLine(64, stemTop, 64, stemBot);
                    u8g2.drawLine(65, stemTop, 65, stemBot);
                }
            }
            break;
        }

        case STATE_YAWN: {
            // Draw Mochi face, cover the mouth, and draw a yawning mouth opening wide
            u8g2.drawXBMP(0, -5, 128, 64, normalFrames[normalFrame]);

            uint32_t elapsed = now - stateStartTs;
            float progress = (float)elapsed / 2000.0f;
            if (progress > 1.0f) progress = 1.0f;

            // Height and width pulse based on sine curve
            float pulse = sin(progress * PI);
            int height = 2 + (int)(pulse * 12.0f);
            int width = 4 + (int)(pulse * 14.0f);

            // Cover mouth area
            u8g2.setDrawColor(0);
            u8g2.drawBox(50, 32, 28, 18);

            // Draw yawning mouth open shape centered at (64, 40)
            u8g2.setDrawColor(1);
            u8g2.drawRBox(64 - width / 2, 40 - height / 2, width, height, 3);
            break;
        }

        case STATE_ROCKET: {
            // Rocket launch animation (Full Screen Y: 70 to -30)
            uint32_t elapsed = now - stateStartTs;
            float t = (float)elapsed / 2500.0f;
            if (t > 1.0f) t = 1.0f;

            int Y = 70 - (int)(t * 105.0f);
            int X = 64;

            for (int i = 0; i < 5; i++) {
                int smokeY = Y + 22 + i * 8;
                if (smokeY < 64) {
                    int radius = 8 - i * 1.5;
                    if (radius > 1) {
                        int smokeX = X + (int)(sin((now + i * 500) / 100.0) * 3.0);
                        u8g2.drawCircle(smokeX, smokeY, radius);
                    }
                }
            }

            u8g2.drawRBox(X - 5, Y, 10, 20, 3);
            u8g2.drawTriangle(X - 5, Y, X + 5, Y, X, Y - 6);
            u8g2.drawTriangle(X - 5, Y + 14, X - 5, Y + 20, X - 10, Y + 20);
            u8g2.drawTriangle(X + 5, Y + 14, X + 5, Y + 20, X + 10, Y + 20);

            int flameLen = random(6, 13);
            u8g2.drawTriangle(X - 3, Y + 20, X + 3, Y + 20, X, Y + 20 + flameLen);
            break;
        }

        case STATE_MIC: {
            u8g2.setFont(u8g2_font_6x10_tf);
            u8g2.setDrawColor(1);
            u8g2.drawStr(16, 37, "* listening.....");
            break;
        }

        case STATE_PLAN: {
            // Pulse brain / neural network nodes
            struct Node { int x; int y; };
            Node nodes[6] = {
                {64, 32}, // Center
                {44, 20}, // Front Left
                {84, 20}, // Front Right
                {40, 44}, // Back Left
                {88, 44}, // Back Right
                {64, 52}  // Stem
            };

            u8g2.drawLine(nodes[0].x, nodes[0].y, nodes[1].x, nodes[1].y);
            u8g2.drawLine(nodes[0].x, nodes[0].y, nodes[2].x, nodes[2].y);
            u8g2.drawLine(nodes[0].x, nodes[0].y, nodes[3].x, nodes[3].y);
            u8g2.drawLine(nodes[0].x, nodes[0].y, nodes[4].x, nodes[4].y);
            u8g2.drawLine(nodes[0].x, nodes[0].y, nodes[5].x, nodes[5].y);
            u8g2.drawLine(nodes[1].x, nodes[1].y, nodes[2].x, nodes[2].y);
            u8g2.drawLine(nodes[1].x, nodes[1].y, nodes[3].x, nodes[3].y);
            u8g2.drawLine(nodes[2].x, nodes[2].y, nodes[4].x, nodes[4].y);
            u8g2.drawLine(nodes[3].x, nodes[3].y, nodes[5].x, nodes[5].y);
            u8g2.drawLine(nodes[4].x, nodes[4].y, nodes[5].x, nodes[5].y);

            for (int i = 0; i < 6; i++) {
                int r = 3 + (int)(sin(now * 0.007f + i) * 2.0f + 2.0f);
                u8g2.drawDisc(nodes[i].x, nodes[i].y, r);
            }

            float dotPos = (float)((now / 10) % 100) / 100.0f;
            int dotX = nodes[1].x + (int)((nodes[0].x - nodes[1].x) * dotPos);
            int dotY = nodes[1].y + (int)((nodes[0].y - nodes[1].y) * dotPos);
            u8g2.drawDisc(dotX, dotY, 3);
            
            dotX = nodes[2].x + (int)((nodes[0].x - nodes[2].x) * dotPos);
            dotY = nodes[2].y + (int)((nodes[0].y - nodes[2].y) * dotPos);
            u8g2.drawDisc(dotX, dotY, 3);
            break;
        }

        case STATE_ESC: {
            uint32_t elapsed = now - stateStartTs;
            // Shrug ¯\(ツ)/¯ animation with subtle shrugging movement
            int handY = 22 + ((elapsed / 250) % 2 == 0 ? -2 : 0);
            int faceY = 28 + ((elapsed / 250) % 2 == 0 ? 1 : 0);
            int armEndY = 40 + ((elapsed / 250) % 2 == 0 ? 0 : -1);

            u8g2.setDrawColor(1);

            // Left Hand ¯
            u8g2.drawHLine(24, handY, 12);
            u8g2.drawHLine(24, handY + 1, 12);

            // Left Arm \
            u8g2.drawLine(36, handY + 1, 48, armEndY);
            u8g2.drawLine(37, handY + 1, 49, armEndY);

            // Left Parenthesis (
            u8g2.drawLine(52, faceY, 50, faceY + 3);
            u8g2.drawLine(53, faceY, 51, faceY + 3);
            u8g2.drawLine(50, faceY + 3, 50, faceY + 13);
            u8g2.drawLine(51, faceY + 3, 51, faceY + 13);
            u8g2.drawLine(50, faceY + 13, 52, faceY + 16);
            u8g2.drawLine(51, faceY + 13, 53, faceY + 16);

            // The Katakana Face ツ
            // Left eye slanted line
            u8g2.drawLine(58, faceY + 2, 60, faceY + 5);
            u8g2.drawLine(59, faceY + 2, 61, faceY + 5);
            // Right eye slanted line
            u8g2.drawLine(64, faceY + 1, 66, faceY + 4);
            u8g2.drawLine(65, faceY + 1, 67, faceY + 4);
            // Smile sweep
            u8g2.drawLine(70, faceY + 3, 67, faceY + 7);
            u8g2.drawLine(71, faceY + 3, 68, faceY + 7);
            u8g2.drawLine(67, faceY + 7, 62, faceY + 11);
            u8g2.drawLine(68, faceY + 7, 63, faceY + 11);
