            // Right Parenthesis )
            u8g2.drawLine(76, faceY, 78, faceY + 3);
            u8g2.drawLine(75, faceY, 77, faceY + 3);
            u8g2.drawLine(78, faceY + 3, 78, faceY + 13);
            u8g2.drawLine(77, faceY + 3, 77, faceY + 13);
            u8g2.drawLine(78, faceY + 13, 76, faceY + 16);
