// ── Per-button state ──────────────────────────────────────────
struct Button {
    uint8_t  pin;
    uint8_t  hidKey;
    bool     physState;      // current debounced physical state (LOW = pressed)
    bool     lastRaw;        // raw GPIO reading last cycle
    uint32_t debounceTs;     // timestamp of last raw edge
    bool     keyDown;        // are we currently reporting this key as held?
    uint32_t pressTs;        // when the key first became "held"
    uint32_t repeatTs;       // last repeat send timestamp
};

Button buttons[6] = {
    { BTN_ESC,    KEY_ESC,    HIGH, HIGH, 0, false, 0, 0 }, // buttons[0] = ESC
    { BTN_MIC,    KEY_SPACE,  HIGH, HIGH, 0, false, 0, 0 }, // buttons[1] = MIC
    { BTN_ACCEPT, KEY_ENTER,  HIGH, HIGH, 0, false, 0, 0 }, // buttons[2] = ACCEPT
    { BTN_PLAN,   KEY_TAB,    HIGH, HIGH, 0, false, 0, 0 }, // buttons[3] = PLAN
    { BTN_UP,     KEY_UP,     HIGH, HIGH, 0, false, 0, 0 }, // buttons[4] = UP
    { BTN_DOWN,   KEY_DOWN,   HIGH, HIGH, 0, false, 0, 0 }, // buttons[5] = DOWN
};

// ── BLE Server Callbacks ──────────────────────────────────────
class ServerCallbacks : public NimBLEServerCallbacks {
#if __has_include("NimBLEConnInfo.h")
    void onConnect(NimBLEServer* pServer, NimBLEConnInfo& connInfo) override {
        isConnected = true;
    }
    void onDisconnect(NimBLEServer* pServer, NimBLEConnInfo& connInfo, int reason) override {
        isConnected = false;
        NimBLEDevice::startAdvertising();
    }
#else
    void onConnect(NimBLEServer* pServer) override {
        isConnected = true;
    }
    void onDisconnect(NimBLEServer* pServer) override {
        isConnected = false;
        NimBLEDevice::startAdvertising();
    }
#endif
};

