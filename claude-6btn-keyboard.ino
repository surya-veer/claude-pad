            u8g2.drawHLine(76, 24, 14);

            // Sleeping mouth — wider flat line
            u8g2.drawHLine(59, 40, 10);
            
            // Floating Zzz animation drifting upwards to the right
            int offset = (now / 50) % 30;
            
            // Z1
            int z1y = 42 - offset;
