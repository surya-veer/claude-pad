// ================= PINS =================
#define BTN_PLAN     0    // Plan (Shift+Tab twice)
#define BTN_ESC      1    // Escape
#define BTN_ACCEPT   2    // Accept / Enter
#define BTN_MIC      3    // Mic / Space hold
#define BTN_DOWN     4    // Arrow Down
#define BTN_UP       21   // Arrow Up
#define PIN_SDA      8    // OLED SDA (GPIO 8)
#define PIN_SCL      9    // OLED SCL (GPIO 9)
#define TOUCH_PIN    20   // Touch Sensor (GPIO 20)
#define SPEAKER_PIN  7    // Buzzer/Speaker (GPIO 7)
#define LED_PIN      47   // Built-in LED (re-assigned to avoid conflict with BTN_UP)
#define I2S_DOUT     2    
#define I2S_BCLK     0    
#define I2S_LRC      1    

// ── HID Usage IDs ─────────────────────────────────────────────
#define KEY_ENTER          0x28
#define KEY_UP             0x52
#define KEY_DOWN           0x51
#define KEY_ESC            0x29
#define KEY_SPACE          0x2C
#define KEY_TAB            0x2B  // Tab key code
#define KEY_LEFT_BRACKET   0x2F  // [ key
#define KEY_RIGHT_BRACKET  0x30  // ] key
#define KEY_F5             0x3E  // F5 key
#define KEY_C              0x06
#define KEY_0              0x27  // Used for ')' key
#define KEY_MOD_LCTRL      0x01
#define KEY_MOD_LSHIFT     0x02
#define KEY_MOD_LGUI       0x08  // Command / Win key

// ── Timing ────────────────────────────────────────────────────
#define DEBOUNCE_MS   40   // debounce window (ms)
#define REPEAT_DELAY  400  // hold-to-repeat first delay (ms)
#define REPEAT_RATE   80   // hold-to-repeat interval (ms)

U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(
  U8G2_R2,
  U8X8_PIN_NONE,
  PIN_SCL,
  PIN_SDA
);

void setupI2S() {
  i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_TX),
    .sample_rate = 22050,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = I2S_COMM_FORMAT_I2S,
    .intr_alloc_flags = 0,
    .dma_buf_count = 8,
    .dma_buf_len = 64,
    .use_apll = false
  };

  i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_BCLK,
    .ws_io_num = I2S_LRC,
    .data_out_num = I2S_DOUT,
    .data_in_num = -1
  };

  i2s_driver_install(I2S_NUM_0, &i2s_config, 0, NULL);
  i2s_set_pin(I2S_NUM_0, &pin_config);
}


